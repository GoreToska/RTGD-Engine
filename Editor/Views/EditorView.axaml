<UserControl
    x:Class="Editor.Views.EditorView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:panels="using:Editor.Views.Panels"
    xmlns:vm="using:Editor.ViewModels"
    x:DataType="vm:EditorViewModel">

    <Grid ColumnDefinitions="240, 0, *, 0, 320" RowDefinitions="*, 0, 200">
        <panels:HierarchyPanel
            Grid.Row="0"
            Grid.Column="0"
            DataContext="{Binding Hierarchy}" />
        <panels:ViewportPanel
            Grid.Row="0"
            Grid.Column="2"
            DataContext="{Binding Viewport}" />
        <panels:InspectorPanel
            Grid.Row="0"
            Grid.Column="4"
            DataContext="{Binding Inspector}" />
        <panels:AssetBrowserPanel
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="5"
            DataContext="{Binding AssetBrowser}" />

        <GridSplitter
            Grid.Row="0"
            Grid.Column="1"
            Classes="editor-splitter"
            ResizeDirection="Columns" />
        <GridSplitter
            Grid.Row="0"
            Grid.Column="3"
            Classes="editor-splitter"
            ResizeDirection="Columns" />
        <GridSplitter
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="5"
            Classes="editor-splitter"
            ResizeDirection="Rows" />
    </Grid>
</UserControl>
