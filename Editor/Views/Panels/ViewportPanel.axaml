<UserControl
    x:Class="Editor.Views.Panels.ViewportPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Editor.Controls"
    xmlns:vm="using:Editor.ViewModels.Panels"
    x:DataType="vm:ViewportViewModel">

    <Border
        Background="{DynamicResource BgCanvas}"
        BorderBrush="{DynamicResource BorderDefault}"
        BorderThickness="2,0">
        <controls:EngineViewportHost x:Name="ViewportHost" />
    </Border>
</UserControl>
