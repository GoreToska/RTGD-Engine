<UserControl
    x:Class="Editor.Views.Panels.HierarchyPanel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Editor.ViewModels.Panels"
    x:DataType="vm:HierarchyViewModel">

    <Border Background="{DynamicResource BgPanel}">
        <TextBlock Text="Hierarchy" />
    </Border>
</UserControl>
