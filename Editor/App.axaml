<Application
    x:Class="Editor.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Editor"
    RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <!--  Palette for Light theme variant  -->
                <ColorPaletteResources
                    x:Key="Light"
                    Accent="#8B5CF6"
                    ErrorText="Red"
                    RegionColor="White" />
                <!--  Palette for Dark theme variant  -->
                <ColorPaletteResources
                    x:Key="Dark"
                    Accent="#2DD4BF"
                    ErrorText="#F87171"
                    RegionColor="#0B0E14" />
            </FluentTheme.Palettes>
        </FluentTheme>

        <StyleInclude Source="avares://Editor/Shared/Themes/Splitter.axaml" />
    </Application.Styles>


    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Editor/Shared/Themes/Colors.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
