<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Editor.App"
             xmlns:local="using:Editor"
             RequestedThemeVariant="Dark"
             >

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <!-- Palette for Light theme variant -->
                <ColorPaletteResources x:Key="Light" Accent="#8B5CF6" RegionColor="White" ErrorText="Red" />
                <!-- Palette for Dark theme variant -->
                <ColorPaletteResources x:Key="Dark" Accent="#8B5CF6" RegionColor="#0D0D0F" ErrorText="Yellow" />
            </FluentTheme.Palettes>
        </FluentTheme>
    </Application.Styles>
</Application>