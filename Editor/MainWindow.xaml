<Window x:Class="Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Editor"
        xmlns:scene="clr-namespace:Editor.Scene"
        xmlns:inspector="clr-namespace:Editor.Inspector"
        Title="RTGD Engine Editor" Width="1280" Height="720"
        Background="#1A1A1A"
        SizeChanged="Window_SizeChanged">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220" MinWidth="150"/>
        </Grid.ColumnDefinitions>

        <!-- Splitter (Hierarchy/Viewport)-->
        <GridSplitter Grid.Column="0"
                      Width="3"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Stretch"
                      Background="#333333"
                      ResizeDirection="Columns"/>

        <!-- Splitter (Viewport/Inspector) -->
        <GridSplitter Grid.Column="2"
                      Width="3"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Stretch"
                      Background="#333333"
                      ResizeDirection="Columns"/>

        <!-- Hierarchy -->
        <scene:SceneHierarchyPanel x:Name="HierarchyPanel"
                                    Grid.Column="0"
                                    EntitySelected="OnEntitySelected"/>

        <!-- Viewport -->
        <Border x:Name="ViewportBorder"
                Grid.Column="1"
                Background="Black"/>

        <!-- Inspector -->
        <inspector:InspectorPanel x:Name="InspectorPanel" Grid.Column="2"/>

    </Grid>
</Window>